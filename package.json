{
  "name": "tabitomo",
  "version": "0.1.0",
  "type": "module",
  "license": "Apache-2.0",
  "author": "BackRunner",
  "packageManager": "pnpm@11.10.0",
  "scripts": {
    "dev": "vite",
    "dev:wrangler": "wrangler pages dev --port 5173 -- vite",
    "build": "vite build",
    "build:analyze": "vite build --mode analyze",
    "lint": "eslint .",
    "preview": "vite preview",
    "test:core": "pnpm --dir packages/tabitomo-core test",
    "test:provider-smoke": "pnpm --dir packages/tabitomo-core exec tsx ../../scripts/provider-smoke.ts",
    "test:mobile:device-qa-report": "node scripts/ios-device-qa-report-check.mjs",
    "test:mobile:ios-xcode-preflight": "node scripts/ios-local-xcode-preflight.mjs",
    "test:mobile:parity-audit": "node scripts/mobile-parity-audit.mjs",
    "test:mobile:release-evidence": "node scripts/mobile-release-evidence.mjs",
    "test:mobile:release-readiness": "node scripts/mobile-release-readiness.mjs",
    "test:mobile:ios-smoke": "pnpm native-runtimes:prepare && node scripts/ios-simulator-smoke.mjs",
    "test:mobile:web-smoke": "node scripts/expo-web-smoke.mjs",
    "test:mobile:icon-parity": "node scripts/sync-mobile-app-icon.mjs --check",
    "test:mobile:model-assets": "node scripts/mobile-model-assets-check.mjs",
    "icons:sync-mobile": "node scripts/sync-mobile-app-icon.mjs",
    "models:publish-mobile": "node scripts/publish-mobile-model.mjs",
    "native-runtimes:prepare": "node scripts/prepare-mobile-native-runtimes.mjs",
    "ios:sync-project": "./scripts/ios-sync-xcode-project.sh",
    "ios:open": "./scripts/ios-open-xcode.sh",
    "ios:install-device": "node scripts/ios-install-device.mjs",
    "ios:set-build-number": "node scripts/ios-set-build-number.mjs",
    "ios:archive": "./scripts/ios-xcode-release.sh archive",
    "ios:upload-testflight": "./scripts/ios-xcode-release.sh upload",
    "test:e2e": "playwright test",
    "test:e2e:ui": "playwright test --ui",
    "test:e2e:headed": "playwright test --headed",
    "test:install": "playwright install --with-deps",
    "deploy": "pnpm build && pnpm test:e2e && wrangler pages deploy dist"
  },
  "dependencies": {
    "@ai-sdk/anthropic": "^4.0.8",
    "@ai-sdk/openai": "^4.0.8",
    "@ai-sdk/openai-compatible": "^3.0.5",
    "@jsquash/jpeg": "^1.6.0",
    "@paddleocr/paddleocr-js": "^0.4.2",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-switch": "^1.3.2",
    "@radix-ui/react-toast": "^1.2.18",
    "ai": "^7.0.16",
    "clsx": "latest",
    "html5-qrcode": "^2.3.8",
    "kuroshiro": "^1.2.0",
    "kuroshiro-analyzer-kuromoji": "^1.1.0",
    "lucide-react": "1.23.0",
    "marked": "^18.0.5",
    "openai": "^6.45.0",
    "path-browserify": "^1.0.1",
    "qrcode": "^1.5.4",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-dropzone": "^15.0.0",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "speech-asr": "^1.1.6",
    "streamdown": "^2.5.0",
    "tailwind-merge": "latest",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/postcss": "^4.3.2",
    "@types/node": "^26.1.0",
    "@types/qrcode": "^1.5.6",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@typescript-eslint/eslint-plugin": "^8.62.1",
    "@typescript-eslint/parser": "^8.62.1",
    "@unocss/preset-typography": "^66.7.4",
    "@unocss/preset-wind": "^66.7.4",
    "@unocss/transformer-directives": "^66.7.4",
    "@unocss/vite": "^66.7.4",
    "@vite-pwa/assets-generator": "^1.0.2",
    "@vitejs/plugin-react": "^6.0.3",
    "autoprefixer": "latest",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "^7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "playwright": "^1.61.1",
    "postcss": "latest",
    "rollup-plugin-visualizer": "^7.0.1",
    "tailwindcss": "4.3.2",
    "typescript": "^6.0.3",
    "unocss": "^66.7.4",
    "vite": "^8.1.3",
    "vite-plugin-pwa": "^1.3.0",
    "workbox-build": "^7.4.1",
    "workbox-window": "^7.4.1",
    "wrangler": "^4.107.0"
  }
}
